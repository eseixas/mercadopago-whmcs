{
    "name": "eseixas/mercadopago-whmcs",
    "description": "Módulo de gateway de pagamento Mercado Pago para WHMCS 8.10+ com suporte a Pix, Cartão de Crédito, Boleto e Webhooks.",
    "type": "whmcs-module",
    "keywords": [
        "whmcs",
        "whmcs-module",
        "whmcs-gateway",
        "mercadopago",
        "mercado-pago",
        "payment-gateway",
        "pix",
        "boleto",
        "cartao-de-credito",
        "brasil",
        "brazil"
    ],
    "homepage": "https://github.com/eseixas/mercadopago-whmcs",
    "license": "GPL-3.0-or-later",
    "authors": [
        {
            "name": "Eduardo Seixas",
            "email": "contato@seixastec.com.br",
            "homepage": "https://github.com/eseixas",
            "role": "Lead Developer"
        }
    ],
    "support": {
        "issues": "https://github.com/eseixas/mercadopago-whmcs/issues",
        "source": "https://github.com/eseixas/mercadopago-whmcs",
        "docs": "https://github.com/eseixas/mercadopago-whmcs/blob/main/README.md"
    },
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "ext-curl": "*",
        "ext-openssl": "*",
        "ext-mbstring": "*",
        "ext-pdo": "*",
        "mercadopago/dx-php": "^3.9",
        "guzzlehttp/guzzle": "^7.8",
        "monolog/monolog": "^3.5",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.11",
        "phpstan/phpstan-strict-rules": "^1.6",
        "friendsofphp/php-cs-fixer": "^3.59",
        "squizlabs/php_codesniffer": "^3.10",
        "rector/rector": "^1.2",
        "mockery/mockery": "^1.6",
        "vimeo/psalm": "^5.25",
        "symfony/var-dumper": "^6.4"
    },
    "suggest": {
        "ext-redis": "Para cache de tokens e idempotência em alta performance",
        "ext-intl": "Para formatação de moeda e localização BR avançada"
    },
    "autoload": {
        "psr-4": {
            "Eseixas\\MercadoPagoWhmcs\\": "src/"
        },
        "files": [
            "src/helpers/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Eseixas\\MercadoPagoWhmcs\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --colors=always",
        "test:coverage": "phpunit --colors=always --coverage-html=build/coverage --coverage-text",
        "test:unit": "phpunit --colors=always --testsuite=Unit",
        "test:integration": "phpunit --colors=always --testsuite=Integration",
        "phpstan": "phpstan analyse --memory-limit=512M",
        "phpstan:baseline": "phpstan analyse --generate-baseline --memory-limit=512M",
        "psalm": "psalm --show-info=true",
        "cs:check": "php-cs-fixer fix --dry-run --diff --verbose",
        "cs:fix": "php-cs-fixer fix --verbose",
        "phpcs": "phpcs --standard=PSR12 src/ tests/",
        "phpcbf": "phpcbf --standard=PSR12 src/ tests/",
        "rector": "rector process --dry-run",
        "rector:fix": "rector process",
        "qa": [
            "@cs:check",
            "@phpstan",
            "@test"
        ],
        "qa:fix": [
            "@cs:fix",
            "@rector:fix"
        ],
        "ci": [
            "@cs:check",
            "@phpstan",
            "@psalm",
            "@test:coverage"
        ],
        "build": [
            "@composer install --no-dev --optimize-autoloader --classmap-authoritative",
            "@php scripts/build-release.php"
        ]
    },
    "scripts-descriptions": {
        "test": "Roda todos os testes (PHPUnit)",
        "test:coverage": "Roda testes com relatório de cobertura HTML",
        "test:unit": "Roda apenas testes unitários",
        "test:integration": "Roda apenas testes de integração",
        "phpstan": "Análise estática nível alto com PHPStan",
        "phpstan:baseline": "Gera baseline do PHPStan (suprime erros existentes)",
        "psalm": "Análise estática com Psalm",
        "cs:check": "Verifica padrão de código (PSR-12) sem alterar arquivos",
        "cs:fix": "Corrige automaticamente padrão de código",
        "phpcs": "Verifica padrão PSR-12 com PHP_CodeSniffer",
        "phpcbf": "Corrige automaticamente com PHP_CodeBeautifier",
        "rector": "Mostra refatorações sugeridas pelo Rector (dry-run)",
        "rector:fix": "Aplica refatorações automáticas do Rector",
        "qa": "Quality Assurance completo (CS + PHPStan + Tests)",
        "qa:fix": "Aplica todas as correções automáticas",
        "ci": "Pipeline de CI completo",
        "build": "Gera pacote de release para distribuição"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.x-dev"
        },
        "whmcs": {
            "min-version": "8.10",
            "module-type": "gateway",
            "module-name": "mercadopago",
            "vendor-name": "seixastec"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "platform-check": true,
        "allow-plugins": {
            "composer/package-versions-deprecated": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
